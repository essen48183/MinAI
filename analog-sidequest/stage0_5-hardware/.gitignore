# macOS Finder metadata
.DS_Store

# VS Code "Local History" extension — accumulates a copy of every saved
# version. Big and per-machine; not part of the design.
.history/

# KiCad lock files (only valid while a session is open)
*.lck
~*.lck

# KiCad per-user editor preferences (zoom, panel layout, recent files,
# etc.) — not part of the design and noisy in diffs.
*.kicad_prl

# KiCad auto-saves and auto-backups (regenerated by KiCad on every save)
*-backups/
_autosave-*
*.bak

# KiCad footprint info cache (rebuilt on open)
fp-info-cache

# Nested git repo inside bom/ — track the files, not the repo state.
bom/.git/
